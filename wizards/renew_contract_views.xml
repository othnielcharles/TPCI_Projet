<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_renew_contract" model="ir.ui.view">
        <field name="name">wizard.renew.contract.form</field>
        <field name="model">wizard.renew.contract</field>
        <field name="arch" type="xml">
            <form string="Renouveler Contrat">
                <group>
                    <field name="contract_id" readonly="1"/>
                    <field name="new_end_date"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </group>
                <footer>
                    <button name="action_renew" string="Renouveler" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_renew_contract" model="ir.actions.act_window">
        <field name="name">Renouveler</field>
        <field name="res_model">wizard.renew.contract</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
