<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_import_equipment" model="ir.ui.view">
        <field name="name">wizard.import.equipment.form</field>
        <field name="model">wizard.import.equipment</field>
        <field name="arch" type="xml">
            <form string="Import CSV Equipements">
                <field name="state" invisible="1"/>
                <div invisible="state == 'done'">
                    <p>Veuillez uploader un fichier CSV contenant les colonnes 'name', 'serial_number', 'category' et 'purchase_value'.</p>
                    <group>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </div>
                <div invisible="state == 'draft'">
                    <group>
                        <field name="report" widget="html" readonly="1"/>
                    </group>
                </div>
                <footer>
                    <button name="action_import" string="Importer" type="object" class="btn-primary" invisible="state == 'done'"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_import_equipment" model="ir.actions.act_window">
        <field name="name">Import Equipements</field>
        <field name="res_model">wizard.import.equipment</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    
    <menuitem id="menu_import_equipment" name="Import CSV" parent="menu_it_equipment" action="action_wizard_import_equipment" sequence="100"/>
</odoo>
