<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_reassign_equipment" model="ir.ui.view">
        <field name="name">wizard.reassign.equipment.form</field>
        <field name="model">wizard.reassign.equipment</field>
        <field name="arch" type="xml">
            <form string="Réaffectation">
                <group>
                    <field name="equipment_id" readonly="1"/>
                    <field name="new_employee_id"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_reassign" string="Réaffecter" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_reassign_equipment" model="ir.actions.act_window">
        <field name="name">Réaffecter</field>
        <field name="res_model">wizard.reassign.equipment</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
