<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="it_parc.Dashboard" owl="1">
        <div class="o_it_parc_dashboard container-fluid py-4">
            <div class="row mb-4">
                <div class="col-12">
                    <h1 class="text-primary fw-bold">Dashboard IT Parc</h1>
                    <p class="text-muted">Vue d'ensemble de votre parc informatique</p>
                </div>
            </div>
            
            <div class="row g-4 mb-4">
                <!-- KPI Total Equipements -->
                <div class="col-md-3">
                    <div class="card h-100 shadow-sm border-0 it-kpi-card" t-on-click="openEquipments">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                            <i class="fa fa-laptop fa-3x text-primary mb-3"></i>
                            <h5 class="text-muted mb-1">Total Équipements</h5>
                            <h2 class="fw-bold mb-0"><t t-esc="state.stats.total_equipments"/></h2>
                        </div>
                    </div>
                </div>
                
                <!-- KPI En Maintenance -->
                <div class="col-md-3">
                    <div class="card h-100 shadow-sm border-0 it-kpi-card" t-on-click="openMaintenance">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                            <i class="fa fa-wrench fa-3x text-warning mb-3"></i>
                            <h5 class="text-muted mb-1">En Maintenance</h5>
                            <h2 class="fw-bold mb-0"><t t-esc="state.stats.in_maintenance"/></h2>
                        </div>
                    </div>
                </div>
                
                <!-- KPI Contrats Actifs -->
                <div class="col-md-3">
                    <div class="card h-100 shadow-sm border-0 it-kpi-card" t-on-click="openContracts">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                            <i class="fa fa-file-text fa-3x text-success mb-3"></i>
                            <h5 class="text-muted mb-1">Contrats Actifs</h5>
                            <h2 class="fw-bold mb-0"><t t-esc="state.stats.active_contracts"/></h2>
                        </div>
                    </div>
                </div>
                
                <!-- KPI Coût Maintenance -->
                <div class="col-md-3">
                    <div class="card h-100 shadow-sm border-0 it-kpi-card">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                            <i class="fa fa-money fa-3x text-danger mb-3"></i>
                            <h5 class="text-muted mb-1">Coût Total Interventions</h5>
                            <h2 class="fw-bold mb-0"><t t-esc="state.stats.total_maintenance_cost"/> €</h2>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-0 py-3">
                            <h5 class="mb-0 fw-bold">Répartition par catégorie</h5>
                        </div>
                        <div class="card-body">
                            <div class="chart-container" style="position: relative; height:300px;">
                                <canvas t-ref="chart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
