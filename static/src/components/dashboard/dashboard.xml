<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="it_parc.Dashboard" owl="1">
        <div class="o_it_parc_dashboard_wahou container-fluid py-4">
            
            <!-- Welcome Header -->
            <div class="d-flex justify-content-between align-items-center mb-4 dashboard-header">
                <div>
                    <h1 class="fw-bold mb-1">Vue d'ensemble du Parc IT</h1>
                    <p class="text-muted mb-0">Rapport en temps réel • <t t-esc="state.today_date"/></p>
                </div>
                <div class="header-actions">
                    <button class="btn btn-primary btn-lg rounded-pill shadow-sm" t-on-click="openEquipments">
                        <i class="fa fa-plus me-2"></i>Nouvel Équipement
                    </button>
                </div>
            </div>
            
            <!-- Top KPIs Row (Glassmorphism Cards) -->
            <div class="row g-4 mb-4">
                
                <!-- Availability KPI -->
                <div class="col-xl-3 col-lg-6">
                    <div class="card kpi-card glass-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="icon-shape bg-primary-soft text-primary rounded-circle">
                                    <i class="fa fa-check-circle"></i>
                                </div>
                                <span class="badge bg-success-soft text-success rounded-pill px-3 py-2">
                                    <i class="fa fa-arrow-up me-1"></i>Sain
                                </span>
                            </div>
                            <h2 class="display-5 fw-bold mb-0 text-dark"><t t-esc="state.stats.availability_rate"/>%</h2>
                            <p class="text-muted mb-0 fw-medium">Taux de Disponibilité</p>
                        </div>
                    </div>
                </div>

                <!-- Equipments in Maintenance -->
                <div class="col-xl-3 col-lg-6">
                    <div class="card kpi-card glass-card clickable" t-on-click="openMaintenance">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="icon-shape bg-warning-soft text-warning rounded-circle">
                                    <i class="fa fa-wrench"></i>
                                </div>
                            </div>
                            <h2 class="display-5 fw-bold mb-0 text-dark"><t t-esc="state.stats.in_maintenance"/></h2>
                            <p class="text-muted mb-0 fw-medium">En Maintenance</p>
                            
                            <!-- Mini Progress -->
                            <div class="mt-3">
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-warning" role="progressbar" 
                                         t-attf-style="width: {{ (state.stats.in_maintenance / (state.stats.total_equipments || 1)) * 100 }}%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contracts -->
                <div class="col-xl-3 col-lg-6">
                    <div class="card kpi-card glass-card clickable" t-on-click="openContracts">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="icon-shape bg-info-soft text-info rounded-circle">
                                    <i class="fa fa-file-signature"></i>
                                </div>
                                <t t-if="state.stats.expiring_contracts.length > 0">
                                    <span class="badge bg-danger-soft text-danger rounded-pill px-3 py-2 heartbeat">
                                        <t t-esc="state.stats.expiring_contracts.length"/> Expirant(s)
                                    </span>
                                </t>
                            </div>
                            <h2 class="display-5 fw-bold mb-0 text-dark"><t t-esc="state.stats.active_contracts"/></h2>
                            <p class="text-muted mb-0 fw-medium">Contrats Actifs</p>
                        </div>
                    </div>
                </div>

                <!-- Total Maintenance Cost -->
                <div class="col-xl-3 col-lg-6">
                    <div class="card kpi-card glass-card gradient-primary">
                        <div class="card-body text-white">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="icon-shape bg-white-20 text-white rounded-circle">
                                    <i class="fa fa-money"></i>
                                </div>
                            </div>
                            <h2 class="display-5 fw-bold mb-0 text-white"><t t-esc="state.stats.total_maintenance_cost"/></h2>
                            <p class="text-white-50 mb-0 fw-medium">Coûts de Maintenance (FCFA)</p>
                            <p class="text-white-50 small mt-2 mb-0">Moyenne: <t t-esc="state.stats.avg_intervention_cost"/> FCFA / interv.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Middle Section: Chart & Feeds -->
            <div class="row g-4">
                
                <!-- Chart Area -->
                <div class="col-xl-8 col-lg-7">
                    <div class="card glass-card h-100">
                        <div class="card-header bg-transparent border-0 pt-4 pb-0">
                            <h5 class="fw-bold mb-0">Répartition par Catégorie</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="chart-container" style="position: relative; height: 350px;">
                                <canvas t-ref="chart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Sidebar Area -->
                <div class="col-xl-4 col-lg-5">
                    
                    <!-- Expiring Contracts -->
                    <div class="card glass-card mb-4" t-if="state.stats.expiring_contracts.length > 0">
                        <div class="card-header bg-transparent border-0 pt-4 pb-2 d-flex align-items-center">
                            <h5 class="fw-bold mb-0 text-danger"><i class="fa fa-exclamation-triangle me-2"></i>Contrats à Renouveler</h5>
                        </div>
                        <div class="card-body pt-0">
                            <ul class="list-group list-group-flush list-custom">
                                <t t-foreach="state.stats.expiring_contracts" t-as="contract" t-key="contract.id">
                                    <li class="list-group-item bg-transparent px-0 py-3 border-bottom border-light">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-0 fw-bold"><t t-esc="contract.name"/></h6>
                                                <small class="text-muted"><t t-esc="contract.partner"/></small>
                                            </div>
                                            <span class="badge bg-danger rounded-pill">J-<t t-esc="contract.days_left"/></span>
                                        </div>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>

                    <!-- Recent Interventions -->
                    <div class="card glass-card h-100">
                        <div class="card-header bg-transparent border-0 pt-4 pb-2">
                            <h5 class="fw-bold mb-0">Dernières Interventions</h5>
                        </div>
                        <div class="card-body pt-0">
                            <div class="timeline mt-3">
                                <t t-foreach="state.stats.recent_interventions" t-as="inv" t-key="inv.id">
                                    <div class="timeline-item d-flex mb-3">
                                        <div class="timeline-icon bg-primary-soft text-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm">
                                            <i class="fa fa-check"></i>
                                        </div>
                                        <div class="timeline-content pb-3 border-bottom border-light flex-grow-1">
                                            <h6 class="mb-1 fw-bold text-dark"><t t-esc="inv.equipment"/></h6>
                                            <p class="mb-0 text-muted small"><t t-esc="inv.name"/> • Par <t t-esc="inv.technician"/></p>
                                            <div class="d-flex justify-content-between align-items-center mt-2">
                                                <span class="text-muted small"><i class="fa fa-calendar-o me-1"></i><t t-esc="inv.date"/></span>
                                                <span class="fw-bold text-dark"><t t-esc="inv.cost"/> FCFA</span>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </t>
</templates>
