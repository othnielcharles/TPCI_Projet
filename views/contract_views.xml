<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_it_contract_form" model="ir.ui.view">
            <field name="name">it.contract.form</field>
            <field name="model">it.contract</field>
            <field name="arch" type="xml">
                <form string="Contrat">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="active,expired,renewed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="days_left"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Équipements couverts" name="equipments">
                                <field name="equipment_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_it_contract_tree" model="ir.ui.view">
            <field name="name">it.contract.tree</field>
            <field name="model">it.contract</field>
            <field name="arch" type="xml">
                <list string="Contrats" decoration-danger="days_left &lt; 30 and state == 'active'" decoration-muted="state == 'expired'">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="days_left"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'" decoration-danger="state == 'expired'" decoration-info="state == 'renewed'"/>
                </list>
            </field>
        </record>

        <record id="action_it_contract" model="ir.actions.act_window">
            <field name="name">Contrats Fournisseurs</field>
            <field name="res_model">it.contract</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
