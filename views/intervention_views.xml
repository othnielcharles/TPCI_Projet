<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_it_intervention_form" model="ir.ui.view">
            <field name="name">it.intervention.form</field>
            <field name="model">it.intervention</field>
            <field name="arch" type="xml">
                <form string="Intervention">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="equipment_id"/>
                                <field name="technician_id"/>
                            </group>
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="duration" widget="float_time"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Rapport d'intervention" name="report">
                                <field name="report"/>
                            </page>
                            <page string="Facturation" name="cost">
                                <group>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_it_intervention_tree" model="ir.ui.view">
            <field name="name">it.intervention.tree</field>
            <field name="model">it.intervention</field>
            <field name="arch" type="xml">
                <list string="Interventions">
                    <field name="name"/>
                    <field name="equipment_id"/>
                    <field name="technician_id"/>
                    <field name="date_start"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'"/>
                </list>
            </field>
        </record>

        <record id="view_it_intervention_calendar" model="ir.ui.view">
            <field name="name">it.intervention.calendar</field>
            <field name="model">it.intervention</field>
            <field name="arch" type="xml">
                <calendar string="Interventions" date_start="date_start" date_stop="date_end" color="technician_id" event_open_popup="true">
                    <field name="name"/>
                    <field name="equipment_id"/>
                </calendar>
            </field>
        </record>

        <record id="action_it_intervention" model="ir.actions.act_window">
            <field name="name">Interventions</field>
            <field name="res_model">it.intervention</field>
            <field name="view_mode">list,calendar,form</field>
        </record>
    </data>
</odoo>
