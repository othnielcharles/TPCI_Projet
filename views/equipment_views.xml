<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_it_equipment_form" model="ir.ui.view">
            <field name="name">it.equipment.form</field>
            <field name="model">it.equipment</field>
            <field name="arch" type="xml">
                <form string="Equipement">
                    <header>
                        <button name="action_affecter" string="Affecter" type="object" class="oe_highlight" invisible="state != 'brouillon'"/>
                        <button name="%(it_parc.action_wizard_reassign_equipment)d" string="Réaffecter" type="action" class="btn-primary" invisible="state != 'affecte'"/>
                        <button name="action_maintenance" string="Mettre en maintenance" type="object" invisible="state not in ('affecte', 'brouillon')"/>
                        <button name="action_retirer" string="Retirer" type="object" invisible="state == 'retire'"/>
                        <button name="action_brouillon" string="Remettre en brouillon" type="object" invisible="state == 'brouillon'"/>
                        <field name="state" widget="statusbar" statusbar_visible="brouillon,affecte,maintenance,retire"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="reference"/>
                            </h1>
                            <h2>
                                <field name="name" placeholder="Ex: Dell Latitude 5520..."/>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="category"/>
                                <field name="serial_number"/>
                            </group>
                            <group>
                                <field name="purchase_date"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="purchase_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="warranty_date"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_it_equipment_tree" model="ir.ui.view">
            <field name="name">it.equipment.tree</field>
            <field name="model">it.equipment</field>
            <field name="arch" type="xml">
                <list string="Equipements">
                    <field name="reference"/>
                    <field name="name"/>
                    <field name="category"/>
                    <field name="serial_number"/>
                    <field name="warranty_date"/>
                    <field name="state" widget="badge" decoration-info="state == 'brouillon'" decoration-success="state == 'affecte'" decoration-warning="state == 'maintenance'" decoration-danger="state == 'retire'"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_it_equipment_search" model="ir.ui.view">
            <field name="name">it.equipment.search</field>
            <field name="model">it.equipment</field>
            <field name="arch" type="xml">
                <search string="Recherche Equipements">
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="serial_number"/>
                    <filter string="En maintenance" name="maintenance" domain="[('state', '=', 'maintenance')]"/>
                    <filter string="Affectés" name="affecte" domain="[('state', '=', 'affecte')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Catégorie" name="group_category" context="{'group_by':'category'}"/>
                        <filter string="État" name="group_state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_it_equipment" model="ir.actions.act_window">
            <field name="name">Equipements</field>
            <field name="res_model">it.equipment</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Créer votre premier équipement informatique !
                </p>
            </field>
        </record>
    </data>
</odoo>
