<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_it_alerte_tree" model="ir.ui.view">
            <field name="name">it.alerte.tree</field>
            <field name="model">it.alerte</field>
            <field name="arch" type="xml">
                <list string="Alertes" decoration-bf="is_read == False" decoration-muted="is_read == True">
                    <field name="date"/>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="is_read" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_it_alerte_form" model="ir.ui.view">
            <field name="name">it.alerte.form</field>
            <field name="model">it.alerte</field>
            <field name="arch" type="xml">
                <form string="Alerte">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="type"/>
                                <field name="is_read"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="equipment_id" invisible="type != 'warranty'"/>
                                <field name="contract_id" invisible="type != 'contract'"/>
                            </group>
                        </group>
                        <group>
                            <field name="message"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_it_alerte" model="ir.actions.act_window">
            <field name="name">Alertes</field>
            <field name="res_model">it.alerte</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
