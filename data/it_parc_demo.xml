            <field name="name">Switch Netgear</field>
            <field name="serial_number">NET-010</field>
            <field name="category">reseau</field>
            <field name="purchase_value">350.0</field>
            <field name="state">brouillon</field>
        </record>

        <!-- Partners (Fournisseurs) -->
        <record id="demo_partner_1" model="res.partner">
            <field name="name">Dell Technologies</field>
            <field name="is_company" eval="True"/>
        </record>
        <record id="demo_partner_2" model="res.partner">
            <field name="name">Apple France</field>
            <field name="is_company" eval="True"/>
        </record>

        <!-- Contracts -->
        <record id="demo_contract_1" model="it.contract">
            <field name="name">Contrat Support Dell</field>
            <field name="partner_id" ref="demo_partner_1"/>
            <field name="start_date" eval="(datetime.date.today() - relativedelta(months=6)).strftime('%Y-%m-%d')"/>
            <field name="end_date" eval="(datetime.date.today() + relativedelta(months=6)).strftime('%Y-%m-%d')"/>
            <field name="amount">5000.0</field>
        </record>
        
        <record id="demo_contract_2" model="it.contract">
            <field name="name">Contrat Apple Care</field>
            <field name="partner_id" ref="demo_partner_2"/>
            <field name="start_date" eval="(datetime.date.today() - relativedelta(months=12)).strftime('%Y-%m-%d')"/>
            <field name="end_date" eval="(datetime.date.today() + relativedelta(days=45)).strftime('%Y-%m-%d')"/>
            <field name="amount">3000.0</field>
        </record>

        <record id="demo_contract_3" model="it.contract">
            <field name="name">Licences Office 365</field>
            <field name="partner_id" ref="demo_partner_1"/>
            <field name="start_date" eval="(datetime.date.today() - relativedelta(months=24)).strftime('%Y-%m-%d')"/>
            <field name="end_date" eval="(datetime.date.today() + relativedelta(days=15)).strftime('%Y-%m-%d')"/>
            <field name="amount">1500.0</field>
        </record>

        <!-- Interventions -->
        <record id="demo_interv_1" model="it.intervention">
            <field name="equipment_id" ref="demo_eq_1"/>
            <field name="date_start" eval="(datetime.datetime.now() - relativedelta(days=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="date_end" eval="(datetime.datetime.now() - relativedelta(days=5) + relativedelta(hours=2)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="cost">120.0</field>
            <field name="state">done</field>
        </record>

        <record id="demo_interv_2" model="it.intervention">
            <field name="equipment_id" ref="demo_eq_2"/>
            <field name="date_start" eval="(datetime.datetime.now() - relativedelta(days=15)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="date_end" eval="(datetime.datetime.now() - relativedelta(days=15) + relativedelta(hours=4)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="cost">350.0</field>
            <field name="state">done</field>
        </record>

        <record id="demo_interv_3" model="it.intervention">
            <field name="equipment_id" ref="demo_eq_3"/>
            <field name="date_start" eval="(datetime.datetime.now() - relativedelta(days=2)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="cost">0.0</field>
            <field name="state">in_progress</field>
        </record>

        <record id="demo_interv_4" model="it.intervention">
            <field name="equipment_id" ref="demo_eq_4"/>
