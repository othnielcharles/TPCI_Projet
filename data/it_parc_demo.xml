            <field name="state">draft</field>
        </record>

        <record id="demo_interv_5" model="it.intervention">
            <field name="equipment_id" ref="demo_eq_6"/>
            <field name="date_start" eval="(datetime.datetime.now() - relativedelta(days=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="date_end" eval="(datetime.datetime.now() - relativedelta(days=30) + relativedelta(hours=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="cost">500.0</field>
            <field name="state">done</field>
        </record>

    </data>
</odoo>
