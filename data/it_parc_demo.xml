        </record>

        <record id="demo_eq_2" model="it.equipment">
            <field name="name">MacBook Pro M2</field>
            <field name="serial_number">MBP-M2-002</field>
            <field name="category">ordinateur</field>
            <field name="purchase_value">2500.0</field>
