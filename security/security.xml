<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Catégorie pour les applications IT -->
        <record id="module_category_it_parc" model="ir.module.category">
            <field name="name">Gestion de Parc Informatique</field>
            <field name="description">Gestion des accès pour le module it_parc</field>
            <field name="sequence">10</field>
        </record>

        <!-- Groupe : IT Technicien -->
        <record id="group_it_technician" model="res.groups">
            <field name="name">IT Technicien</field>
            <field name="category_id" ref="module_category_it_parc"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Peut voir les équipements et créer des interventions.</field>
        </record>

        <!-- Groupe : IT Manager -->
        <record id="group_it_manager" model="res.groups">
            <field name="name">IT Manager</field>
            <field name="category_id" ref="module_category_it_parc"/>
            <field name="implied_ids" eval="[(4, ref('group_it_technician'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Accès complet à toutes les fonctionnalités du module it_parc.</field>
        </record>
    </data>
</odoo>
